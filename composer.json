{
    "name": "webstrategy/ws-brevo-form-connector",
    "description": "WS Brevo Form Connector WordPress plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^1.0"
    },
    "autoload-dev": {
        "psr-4": {
            "WsBrevoFC\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":          "vendor/bin/phpunit --no-coverage",
        "test:coverage": "vendor/bin/phpunit --coverage-html coverage/html --coverage-clover coverage/clover.xml --coverage-text"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
